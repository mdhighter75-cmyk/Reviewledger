# Copy this file to .env.local for local development.
# In production, set these in your Vercel project settings (Settings → Environment Variables).
# Never commit real keys to GitHub.

# Get this from console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Get these from dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...

# Create a $19/month recurring Price in Stripe Dashboard → Product catalog,
# then paste its Price ID (starts with "price_") here
STRIPE_PRICE_ID=price_...
